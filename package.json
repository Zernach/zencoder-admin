{
  "name": "zencoder-admin",
  "private": true,
  "engines": {
    "node": ">=22 <24"
  },
  "main": "expo-router/entry",
  "scripts": {
    "clean": "rm -rf node_modules ios android .expo package-lock.json dist && npm install",
    "figma:sync": "node --experimental-strip-types docs/designs/src/index.ts",
    "ralph": "sh docs/ralph/ralph.sh",
    "start": "expo start -c",
    "web": "expo start --web -c",
    "android": "expo run:android -c",
    "ios": "expo run:ios -c",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "build": "expo export --platform web",
    "deploy": "npm run build && npx wrangler pages deploy ./dist --project-name=zencoder-submission"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@shopify/react-native-skia": "2.4.18",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dotenv": "^17.3.1",
    "expo": "^55.0.4",
    "expo-blur": "^55.0.8",
    "expo-constants": "^55.0.7",
    "expo-linear-gradient": "^55.0.8",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.3",
    "expo-status-bar": "^55.0.4",
    "expo-system-ui": "^55.0.9",
    "i18next": "^25.8.17",
    "lucide-react-native": "^0.575.0",
    "moti": "^0.30.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.2.0",
    "victory-native": "^41.20.2",
    "wrangler": "^4.69.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "version": "1.0.0"
}
