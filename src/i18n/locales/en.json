          "message": "How is the supply chain performing this week? Summarize OTIF, disruption alerts handled, and any standout service lines."
        },
        "activity": {
          "label": "Show me today's supply-chain activity",
          "message": "Give me a summary of today's supply-chain activity — workflow-app runs, substitutions, alerts, and anything unusual."
        },
        "teams": {
          "label": "Which facilities are most active?",
          "message": "Which facilities have been most active recently? Show me a breakdown of workflow-app usage by hospital."
        },
        "issues": {
          "label": "Any issues I should know about?",
          "message": "Are there any disruptions, stockout risks, or compliance violations I should be aware of? Flag anything critical."
        }
      },
      "agents": {
        "errors": {
          "label": "Which workflow apps have the most errors?",
          "message": "Which workflow apps have the highest error rates right now? List them with failure counts and recent trends."
        },
        "compare": {
          "label": "Compare top workflow apps by success rate",
          "message": "Compare my top workflow apps by success rate this month. Show rankings and any notable changes."
        },
        "inactive": {
          "label": "List inactive workflow apps",
          "message": "List workflow apps that haven't run in the past 7 days. Are any of them supposed to be active?"
        },
        "history": {
          "label": "Explain a workflow app's recent run history",
          "message": "Pick the workflow app with the most interesting recent activity and walk me through its run history."
        }
      },
      "costs": {
        "trending": {
          "label": "Where is supply spend trending upwards?",
          "message": "Where is supply spend trending upward? Show me which service lines or facilities are driving the increase."
        },
        "breakdown": {
          "label": "Show supply spend by facility",
          "message": "Break down supply spend by facility for this month. How does it compare to last month?"
        },
        "unusual": {
          "label": "Flag unusual spending",
          "message": "Flag any unusual or unexpected spending patterns. Are there off-contract orders or cost spikes I should investigate?"
        },
        "reduce": {
          "label": "How can I reduce supply spend?",
          "message": "Analyze current workflow-app usage and procedure cards, and suggest ways to reduce supply spend without clinical impact."
        }
      },
      "governance": {
        "violations": {
          "label": "Any new compliance violations?",
          "message": "Are there any new compliance violations since my last review? Summarize severity and affected workflow apps."
        },
        "compliance": {
          "label": "Show compliance summary",
          "message": "Give me an overall compliance summary — how many rules (HIPAA, DSCSA, UDI) are passing, failing, or need attention?"
        },
        "unresolved": {
          "label": "List unresolved violations",
          "message": "List all unresolved compliance violations sorted by severity. Which ones should I prioritize?"
